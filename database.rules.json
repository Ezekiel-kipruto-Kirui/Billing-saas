{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      ".indexOn": ["email"]
    },
    "tenants": {
      ".indexOn": ["email"],
      "$tenantId": {
        "customers": {
          ".indexOn": ["phone", "status", "expiry_date"]
        },
        "packages": {
          ".indexOn": ["name"]
        },
        "payments": {
          ".indexOn": ["paid_at", "status", "phone"]
        }
      }
    },
    "admin_audit_logs": {
      ".indexOn": ["timestamp", "admin_email", "action"]
    }
  }
}
